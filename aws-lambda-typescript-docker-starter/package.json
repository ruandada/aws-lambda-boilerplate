{
  "name": "aws-lambda-typescript-docker-starter",
  "version": "0.1.0",
  "private": true,
  "description": "TypeScript AWS Lambda starter with local HTTP debugging.",
  "main": "dist/lambda.js",
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/**/*.test.ts",
    "dev": "tsx watch src/local.ts",
    "start": "node dist/local.js",
    "start:lambda": "node dist/lambda.js"
  },
  "dependencies": {
    "@codegenie/serverless-express": "^4.17.1",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.161",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
